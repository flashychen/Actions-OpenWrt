# 1. 基础架构设置
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 2. 开启内核 BTF 支持 (解决 no BTF found)
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_BTF=y
# 必须显式关闭简版调试信息，否则 BTF 不完整
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set

# 3. 开启 eBPF 必须的内核模块 (解决 kmod-uprobes 报错)
CONFIG_PACKAGE_kmod-uprobes=y
CONFIG_PACKAGE_kmod-bpf=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_KERNEL_KPROBES=y
CONFIG_KERNEL_UPROBES=y

# 4. 加入 daed 面板和插件
CONFIG_PACKAGE_daed=y
CONFIG_PACKAGE_luci-app-daed=y
# 增大内核分区到 128MB 或 3072MB
CONFIG_TARGET_KERNEL_PARTSIZE=3072
# 增大根文件系统分区到 3072MB (方便以后装更多插件)
CONFIG_TARGET_ROOTFS_PARTSIZE=3072
